{
  "buildCommand": "cd web && npm ci && npm run build",
  "outputDirectory": "web/dist",
  "devCommand": "cd web && npm run dev",
  "installCommand": "cd web && npm ci",
  "framework": "vite",
  "rewrites": [
    { "source": "/coquchemas/data/products.json", "destination": "/web/src/data/products.json" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
